{
  "_version": "LDM — VAE + Conditional DiT",
  "_architecture": "Stage 1: KL-VAE (f=4) fine-tuned on LWIR | Stage 2: DiT-B/4 conditioned on MWIR",

  "data_root": "data/ir_pairs",
  "file_ext": "npy",
  "output_dir": "runs/mwir2lwir_ldm",

  "mwir_channels": 1,
  "lwir_channels": 1,
  "image_size": 256,
  "_latent_dims": "256/4=64 → latent 64×64×4=16384 dims. DiT patch_size=4 → 16×16=256 patch tokens + 4 registers = 260 total.",
  "val_frac": 0.1,
  "num_workers": 8,

  "_stage1_vae": "Fine-tune KL-VAE on LWIR imagery",
  "sd_vae_path": "./pretrained_weights/sd_vae/diffusion_pytorch_model.safetensors",
  "vae_finetuned_weights_filename": "vae_final_19MAR2026.pt",
  "vae_ch": 128,
  "vae_ch_mult": [1, 2, 4],
  "vae_num_res_blocks": 2,
  "z_channels": 4,
  "vae_f": 4,
  "vae_lr": 4.5e-6,
  "vae_batch_size": 16,
  "vae_total_steps": 40000,
  "kl_weight_start": 1e-7,
  "kl_weight_max": 1e-4,
  "kl_warmup_steps": 10000,

  "_stage2_dit": "Conditional DiT-B/4 in latent space",
  "dit_size": "B",
  "dit_context_dim": 512,
  "dit_cond_dim": 1024,
  "num_registers": 4,
  "dit_lr": 1e-4,
  "dit_batch_size": 8,
  "dit_total_steps": 200000,
  "warmup_steps": 2000,
  "ema_decay": 0.9999,
  "cfg_prob": 0.1,

  "num_train_timesteps": 1000,
  "noise_schedule": "cosine",

  "_flow_matching": "Flow Matching replaces DDPM — set use_flow_matching: false to revert to DDPM",
  "use_flow_matching": false,
  "fm_time_sampling": "logit_normal",
  "fm_logit_loc": 0.0,
  "fm_logit_scale": 1.0,
  "fm_loss_weighting": "constant",

  "snr_gamma": 5.0,

  "lambda_cfc": 0.10,
  "lambda_spectral": 0.05,
  "weight_decay": 1e-4,

  "_planck_loss": "Fill in your actual calibration coefficients before enabling",
  "use_plank_loss": false,
  "planck": {
    "lambda_planck": 0.05,
    "mwir_wavelength_um": 4.0,
    "lwir_wavelength_um": 10.0,
    "mwir_gain":   0.01,
    "mwir_offset": -0.5,
    "lwir_gain":   0.005,
    "lwir_offset": 200.0,
    "mwir_norm_min": 88.0,
    "mwir_norm_max": 3804.0,
    "lwir_norm_min": 1622.0,
    "lwir_norm_max": 3836.0,
    "allowed_delta_K": 15.0,
    "use_confidence": true,
    "confidence_sigma": 2.0,

    "_added_from_data": "Added from data",
    "lwir_rad_to_bt_k1": 1585.468485,
    "lwir_rad_to_bt_k2": 188.801657,
    "_lwir_radiance_to_bt_formula": "(lwir_rad_to_bt_k1/log((lwir_rad_to_bt_k2/lwir_radiance) + 1))",
    "lwir_saturation_radiance": 1.989696,
    "lwir_saturation_temp": 347.446740,
    "lwir_count_to_rad": 0.000207,
    "_lwir_count_to_rad_formula": "lwir_count * lwir_count_to_rad",
    "lwir_calibration_gain": 0.788820,
    "lwir_calibration_offset": 51.879417,
    "_lwir_calibration_formula": "lwir_calibrated_bt = lwir_bt * lwir_calibration_gain + lwir_calibration_offset",

    "mwir_rad_to_bt_k1": 3327.998516,
    "mwir_rad_to_bt_k2": 7307.514371,
    "_mwir_radiance_to_bt_formula": "(mwir_rad_to_bt_k1/log((mwir_rad_to_bt_k2/mwir_radiance) + 1))",
    "mwir_saturation_radiance": 4.041386,
    "mwir_saturation_temp": 443.696235,
    "mwir_count_to_rad": 0.000269,
    "_mwir_count_to_rad_formula": "mwir_count * mwir_count_to_rad",
    "mwir_calibration_gain": 0.970713,
    "mwir_calibration_offset": 14.533715,
    "_mwir_calibration_formula": "mwir_calibrated_bt = mwir_bt * mwir_calibration_gain + mwir_calibration_offset"
  },

  "log_every": 50,
  "val_every": 2000,
  "save_every": 5000,

  "_swath_geometry": "Real-world sensor swath widths — used by SceneAdaptiveInference at deployment",
  "mwir_swath_km": 3.0,
  "lwir_swath_km": 2.0,

  "_inference_defaults": {
    "guidance_scale": 5.0,
    "num_steps": 50,
    "note": "CFG scale 3-7 is the key knob at inference. Higher = sharper but less diverse."
  },

  "_tuning_for_500_2000_pairs": {
    "vae_total_steps": "50k is sufficient if fine-tuning from SD. Increase to 100k if training from scratch.",
    "dit_total_steps": "200k with heavy augmentation. Monitor val PSNR plateau.",
    "cfg_prob": "0.1 (10%) is standard. Increase to 0.15 if CFG guidance is weak at inference.",
    "guidance_scale": "Start at 3.0, increase to 7.0. Above 7 causes mode collapse.",
    "dit_size": "B is recommended. Use S if PSNR is similar but training is slow.",
    "vae_f": "f=4 preserves more texture than f=8 for IR. Do not change unless memory constrained."
  },
  "vis_n_samples": 8,
  "vis_seed": 42,
  "vis_every": 2000
}
