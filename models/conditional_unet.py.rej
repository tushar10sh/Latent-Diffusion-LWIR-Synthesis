--- 26,36 -----
+ def zero_module(module: nn.Module) -> nn.Module:
+     """
+     Zero-initialise all parameters of a module.
+ 
+     IMPORTANT: only call this on modules that are NOT wrapped with
+     spectral_norm. spectral_norm normalises the weight by its spectral
+     norm σ = ||W||_2. If W = 0 then σ = 0 and W/σ = 0/0 = NaN on the
+     first forward pass, regardless of precision.
+ 
+     For residual output convolutions use zero_conv() instead.
+     """
