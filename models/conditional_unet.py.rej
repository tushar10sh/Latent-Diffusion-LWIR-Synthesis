*** 0
--- 41,58 -----
+ 
+ def zero_conv(in_c: int, out_c: int, kernel: int = 1, padding: int = 0) -> nn.Conv2d:
+     """
+     Plain Conv2d (no spectral_norm) with zero weight initialisation.
+ 
+     Used for residual output projections where the intent is 'identity at
+     init'. Spectral_norm must NOT be applied here: spectral_norm divides
+     the weight by its spectral norm, and zero / zero = NaN.
+ 
+     A plain Conv2d with zero weight is safe: it outputs 0 initially,
+     making the residual branch a no-op, which is the intended behaviour.
+     """
+     conv = nn.Conv2d(in_c, out_c, kernel, padding=padding, bias=True)
+     nn.init.zeros_(conv.weight)
+     nn.init.zeros_(conv.bias)
+     return conv
+ 
+ 
